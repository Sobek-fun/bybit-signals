+def build_near_ideal_tp_sl_pairs(
+    frame: pd.DataFrame,
+    near_ideal_tp_sl_pair_weight: float,
+    near_ideal_tp_sl_max_age_distance: int,
+    near_ideal_tp_sl_max_pairs_per_episode: int,
+) -> pd.DataFrame:
+    _require_columns(
+        frame,
+        [
+            "episode_id",
+            "decision_row_id",
+            "episode_age_bars",
+            "row_trade_outcome",
+            "is_ideal_entry",
+            "trainable_row",
+        ],
+        "frame",
+    )
+    pair_weight = float(near_ideal_tp_sl_pair_weight)
+    if pair_weight <= 0.0:
+        raise ValueError("near_ideal_tp_sl_pair_weight must be positive")
+    max_age_distance = int(near_ideal_tp_sl_max_age_distance)
+    if max_age_distance < 0:
+        raise ValueError("near_ideal_tp_sl_max_age_distance must be non-negative")
+    max_pairs = int(near_ideal_tp_sl_max_pairs_per_episode)
+    if max_pairs < 0:
+        raise ValueError("near_ideal_tp_sl_max_pairs_per_episode must be non-negative")
+    if max_pairs == 0 or frame.empty:
+        return pd.DataFrame(columns=list(_PAIR_COLUMNS))
+    local = frame.copy()
+    local["trainable_row"] = local["trainable_row"].astype(bool)
+    local = local[local["trainable_row"]].copy()
+    if local.empty:
+        return pd.DataFrame(columns=list(_PAIR_COLUMNS))
+    local["episode_id"] = local["episode_id"].astype(str)
+    local["decision_row_id"] = local["decision_row_id"].astype(str)
+    local["episode_age_bars"] = pd.to_numeric(local["episode_age_bars"], errors="coerce")
+    local["row_trade_outcome"] = (
+        local["row_trade_outcome"].astype(str).str.strip().str.lower()
+    )
+    local["is_ideal_entry"] = local["is_ideal_entry"].astype(bool)
+    local = local[local["episode_age_bars"].notna()].copy()
+    if local.empty:
+        return pd.DataFrame(columns=list(_PAIR_COLUMNS))
+    rows: list[dict[str, object]] = []
+    for episode_id, group in local.groupby("episode_id", sort=False):
+        ideal = group[group["is_ideal_entry"]].copy()
+        if ideal.empty:
+            continue
+        ideal_row = ideal.sort_values(
+            ["episode_age_bars", "decision_row_id"], kind="mergesort"
+        ).iloc[0]
+        ideal_age = float(ideal_row["episode_age_bars"])
+        ideal_decision_row_id = str(ideal_row["decision_row_id"])
+        sl_rows = group[group["row_trade_outcome"] == "sl"].copy()
+        if sl_rows.empty:
+            continue
+        sl_rows["age_distance_abs"] = (
+            pd.to_numeric(sl_rows["episode_age_bars"], errors="coerce") - ideal_age
+        ).abs()
+        sl_rows = sl_rows[sl_rows["age_distance_abs"] <= float(max_age_distance)].copy()
+        if sl_rows.empty:
+            continue
+        sl_rows = sl_rows.sort_values(
+            ["age_distance_abs", "episode_age_bars", "decision_row_id"],
+            kind="mergesort",
+        ).head(max_pairs)
+        for sl_row in sl_rows.itertuples(index=False):
+            rows.append(
+                {
+                    "episode_id": str(episode_id),
+                    "better_decision_row_id": ideal_decision_row_id,
+                    "worse_decision_row_id": str(sl_row.decision_row_id),
+                    "pair_type": "near_ideal_tp_vs_sl",
+                    "pair_weight": pair_weight,
+                }
+            )
+    if not rows:
+        return pd.DataFrame(columns=list(_PAIR_COLUMNS))
+    return pd.DataFrame(rows, columns=list(_PAIR_COLUMNS)).reset_index(drop=True)
+
