+def _apply_ideal_zone_positive_weight_shaping(
+    frame: pd.DataFrame,
+    sample_weight: np.ndarray,
+    ideal_entry_weight_multiplier: float,
+    near_ideal_tp_weight_multiplier: float,
+    far_tp_weight_multiplier: float,
+    near_ideal_max_bars: int,
+) -> np.ndarray:
+    _require_columns(
+        frame,
+        [
+            "episode_id",
+            "decision_row_id",
+            "target_reason",
+            "is_ideal_entry",
+            "ideal_entry_row_id",
+            "episode_age_bars",
+        ],
+        "frame",
+    )
+    weights = np.asarray(sample_weight, dtype=np.float32).copy()
+    if len(weights) != len(frame):
+        raise ValueError("sample_weight length must match frame length")
+    work = frame.copy()
+    work["episode_id"] = work["episode_id"].astype(str)
+    work["decision_row_id"] = work["decision_row_id"].astype(str)
+    work["target_reason"] = work["target_reason"].astype(str).str.strip().str.lower()
+    work["is_ideal_entry"] = work["is_ideal_entry"].astype(bool)
+    work["ideal_entry_row_id"] = work["ideal_entry_row_id"].astype(str)
+    work["episode_age_bars"] = pd.to_numeric(work["episode_age_bars"], errors="coerce")
+    for _, group in work.groupby("episode_id", sort=False):
+        tp_rows = group[group["target_reason"] == "tp"].copy()
+        if tp_rows.empty:
+            continue
+        ideal_rows = tp_rows[tp_rows["is_ideal_entry"]].copy()
+        if ideal_rows.empty:
+            continue
+        ideal_ref = ideal_rows.iloc[0]
+        ideal_age = float(ideal_ref["episode_age_bars"])
+        if not np.isfinite(ideal_age):
+            continue
+        ideal_row_id = str(ideal_ref["ideal_entry_row_id"])
+        idxs = tp_rows.index.to_numpy(dtype=int)
+        row_ids = tp_rows["decision_row_id"].to_numpy(dtype=object)
+        row_ages = tp_rows["episode_age_bars"].to_numpy(dtype=float)
+        for idx, row_id, row_age in zip(idxs, row_ids, row_ages, strict=False):
+            if str(row_id) == ideal_row_id:
+                weights[idx] *= np.float32(ideal_entry_weight_multiplier)
+                continue
+            if np.isfinite(row_age) and abs(float(row_age) - ideal_age) <= float(
+                near_ideal_max_bars
+            ):
+                weights[idx] *= np.float32(near_ideal_tp_weight_multiplier)
+            else:
+                weights[idx] *= np.float32(far_tp_weight_multiplier)
+    return weights
+
