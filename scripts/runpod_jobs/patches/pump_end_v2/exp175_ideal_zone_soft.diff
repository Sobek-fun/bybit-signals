+def build_ideal_tp_ranking_pairs(
+    frame: pd.DataFrame, ideal_tp_pair_weight: float
+) -> pd.DataFrame:
+    _require_columns(
+        frame,
+        [
+            "episode_id",
+            "decision_row_id",
+            "episode_age_bars",
+            "row_trade_outcome",
+            "is_ideal_entry",
+            "trainable_row",
+        ],
+        "frame",
+    )
+    pair_weight = float(ideal_tp_pair_weight)
+    if pair_weight <= 0.0:
+        raise ValueError("ideal_tp_pair_weight must be positive")
+    if frame.empty:
+        return pd.DataFrame(columns=list(_PAIR_COLUMNS))
+    local = frame.copy()
+    local["trainable_row"] = local["trainable_row"].astype(bool)
+    local = local[local["trainable_row"]].copy()
+    if local.empty:
+        return pd.DataFrame(columns=list(_PAIR_COLUMNS))
+    local["episode_id"] = local["episode_id"].astype(str)
+    local["decision_row_id"] = local["decision_row_id"].astype(str)
+    local["row_trade_outcome"] = (
+        local["row_trade_outcome"].astype(str).str.strip().str.lower()
+    )
+    local["is_ideal_entry"] = local["is_ideal_entry"].astype(bool)
+    rows: list[dict[str, object]] = []
+    for episode_id, group in local.groupby("episode_id", sort=False):
+        ideal = group[group["is_ideal_entry"]].copy()
+        if len(ideal) != 1:
+            continue
+        ideal_row = ideal.iloc[0]
+        ideal_decision_row_id = str(ideal_row["decision_row_id"])
+        tp_rows = group[group["row_trade_outcome"] == "tp"].copy()
+        if tp_rows.empty:
+            continue
+        other_tp_rows = tp_rows[tp_rows["decision_row_id"] != ideal_decision_row_id].copy()
+        if other_tp_rows.empty:
+            continue
+        for tp_row in other_tp_rows.itertuples(index=False):
+            rows.append(
+                {
+                    "episode_id": str(episode_id),
+                    "better_decision_row_id": ideal_decision_row_id,
+                    "worse_decision_row_id": str(tp_row.decision_row_id),
+                    "pair_type": "ideal_tp_vs_other_tp",
+                    "pair_weight": pair_weight,
+                }
+            )
+    if not rows:
+        return pd.DataFrame(columns=list(_PAIR_COLUMNS))
+    return pd.DataFrame(rows, columns=list(_PAIR_COLUMNS)).reset_index(drop=True)
+
