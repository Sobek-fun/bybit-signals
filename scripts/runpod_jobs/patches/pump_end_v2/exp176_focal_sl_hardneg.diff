+def _weighted_main_binary_loss(
+    logits: Tensor,
+    targets: Tensor,
+    sample_weight: Tensor,
+    main_loss_mode: str,
+    focal_gamma: float,
+) -> Tensor:
+    mode = str(main_loss_mode).strip().lower()
+    if mode == "bce":
+        return _weighted_bce_loss(logits, targets, sample_weight)
+    if mode != "focal":
+        raise ValueError("main_loss_mode must be one of: bce, focal")
+    bce = F.binary_cross_entropy_with_logits(logits, targets, reduction="none")
+    p = torch.sigmoid(logits)
+    pt = targets * p + (1.0 - targets) * (1.0 - p)
+    focal_factor = (1.0 - pt) ** float(focal_gamma)
+    per_row_loss = focal_factor * bce
+    weights = torch.clamp(sample_weight, min=0.0)
+    denom = torch.sum(weights)
+    if float(denom.item()) <= 0.0:
+        return torch.zeros((), dtype=per_row_loss.dtype, device=per_row_loss.device)
     return torch.sum(per_row_loss * weights) / denom
 
 
