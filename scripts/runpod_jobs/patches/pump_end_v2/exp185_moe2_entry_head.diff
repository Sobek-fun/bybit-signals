+def _router_balance_loss(router_probs: Tensor | None, device: torch.device) -> Tensor:
+    if router_probs is None or int(router_probs.shape[0]) == 0:
+        return torch.zeros((), dtype=torch.float32, device=device)
+    target = torch.tensor([0.5, 0.5], dtype=router_probs.dtype, device=router_probs.device)
+    mean_load = torch.mean(router_probs, dim=0)
+    return torch.mean((mean_load - target) ** 2)
+
