+def _smooth_ap_loss(scores: Tensor, outcome_targets: Tensor, tau: float, eps: float = 1e-12) -> Tensor:
+    valid_mask = (outcome_targets == 0) | (outcome_targets == 2)
+    if int(valid_mask.sum().item()) < 2:
+        return scores.new_tensor(0.0)
+    scores_v = scores[valid_mask]
+    labels = (outcome_targets[valid_mask] == 0).to(dtype=scores.dtype)
+    pos_mask = labels > 0.5
+    neg_mask = labels < 0.5
+    if not bool(pos_mask.any().item()) or not bool(neg_mask.any().item()):
+        return scores.new_tensor(0.0)
+    score_diff = (scores_v.unsqueeze(1) - scores_v.unsqueeze(0)) / float(tau)
+    r = torch.sigmoid(score_diff)
+    numerators = torch.sum(r * labels.unsqueeze(1), dim=0)
+    denominators = torch.sum(r, dim=0).clamp_min(float(eps))
+    precision = numerators / denominators
+    smooth_ap = precision[pos_mask].mean()
+    return 1.0 - smooth_ap
