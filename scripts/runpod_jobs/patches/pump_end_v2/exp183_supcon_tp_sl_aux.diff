+def _supervised_contrastive_loss(embeddings: Tensor, labels: Tensor, temperature: float) -> Tensor:
+    valid_mask = (labels == 0) | (labels == 1)
+    if int(valid_mask.sum().item()) < 2:
+        return embeddings.new_tensor(0.0)
+    z = F.normalize(embeddings[valid_mask], dim=1)
+    y = labels[valid_mask]
+    labels_unique = torch.unique(y)
+    if int(labels_unique.numel()) < 2:
+        return embeddings.new_tensor(0.0)
+    for cls in (0, 1):
+        cls_count = int((y == int(cls)).sum().item())
+        if cls_count < 2:
+            return embeddings.new_tensor(0.0)
+    same = y.unsqueeze(0) == y.unsqueeze(1)
+    eye = torch.eye(int(y.shape[0]), device=y.device, dtype=torch.bool)
+    positive_mask = same & (~eye)
+    has_positive = positive_mask.any(dim=1)
+    if not bool(has_positive.any().item()):
+        return embeddings.new_tensor(0.0)
+    logits = torch.matmul(z, z.transpose(0, 1)) / float(temperature)
+    logits = logits - torch.max(logits, dim=1, keepdim=True).values.detach()
+    logits_mask = ~eye
+    exp_logits = torch.exp(logits) * logits_mask.to(dtype=logits.dtype)
+    denom = torch.sum(exp_logits, dim=1, keepdim=True).clamp_min(1e-12)
+    log_prob = logits - torch.log(denom)
+    pos_counts = positive_mask.sum(dim=1).clamp_min(1).to(dtype=log_prob.dtype)
+    pos_mean_log_prob = (log_prob * positive_mask.to(dtype=log_prob.dtype)).sum(dim=1) / pos_counts
+    return -pos_mean_log_prob[has_positive].mean()
