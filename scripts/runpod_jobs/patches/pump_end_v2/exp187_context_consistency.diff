+def _consistency_loss(
+    model: SequenceTCNBinaryClassifier,
+    batch_x: Tensor,
+    batch_readout: Tensor,
+    sample_weight: Tensor,
+    clean_entry_logits: Tensor,
+    clean_outcome_logits: Tensor,
+    consistency_mode: str,
+    consistency_noise_std: float,
+    consistency_mask_prob: float,
+) -> Tensor:
+    mode = str(consistency_mode).strip().lower()
+    if mode == "none":
+        return clean_entry_logits.new_tensor(0.0)
+    if mode != "gaussian_context":
+        return clean_entry_logits.new_tensor(0.0)
+    aug_x = _augment_context_view(
+        x=batch_x,
+        readout_index=batch_readout,
+        noise_std=float(consistency_noise_std),
+        mask_prob=float(consistency_mask_prob),
+    )
+    aug_entry_logits, aug_outcome_logits = model(aug_x, batch_readout)
+    active = torch.clamp(sample_weight, min=0.0) > 0
+    if not bool(active.any().item()):
+        return clean_entry_logits.new_tensor(0.0)
+    mse = F.mse_loss(aug_entry_logits[active], clean_entry_logits[active], reduction="mean")
+    clean_probs = torch.softmax(clean_outcome_logits[active], dim=1).clamp_min(1e-12)
+    aug_log_probs = torch.log_softmax(aug_outcome_logits[active], dim=1)
+    kl = F.kl_div(aug_log_probs, clean_probs, reduction="batchmean", log_target=False)
+    return mse + 0.5 * kl
+
+
+def _augment_context_view(
+    x: Tensor,
+    readout_index: Tensor,
+    noise_std: float,
+    mask_prob: float,
+) -> Tensor:
+    aug = x.clone()
+    if aug.ndim != 3 or int(aug.shape[2]) < 3:
+        return aug
+    feature_count = int(aug.shape[2]) - 2
+    valid_mask = aug[:, :, feature_count] > 0.5
+    in_episode_mask = aug[:, :, feature_count + 1] > 0.5
+    step_idx = torch.arange(int(aug.shape[1]), device=aug.device).unsqueeze(0)
+    readout = torch.clamp(
+        readout_index.to(device=aug.device, dtype=torch.long),
+        min=0,
+        max=max(int(aug.shape[1]) - 1, 0),
+    ).unsqueeze(1)
+    not_readout = step_idx != readout
+    pre_context = ~in_episode_mask
+    perturb_mask = valid_mask & not_readout & pre_context
+    if noise_std > 0.0:
+        noise = torch.randn_like(aug[:, :, :feature_count]) * float(noise_std)
+        aug[:, :, :feature_count] = aug[:, :, :feature_count] + noise * perturb_mask.unsqueeze(-1).to(dtype=aug.dtype)
+    if mask_prob > 0.0:
+        drop = (torch.rand_like(aug[:, :, :feature_count]) < float(mask_prob)).to(dtype=aug.dtype)
+        keep = 1.0 - drop * perturb_mask.unsqueeze(-1).to(dtype=aug.dtype)
+        aug[:, :, :feature_count] = aug[:, :, :feature_count] * keep
+    return aug
+
