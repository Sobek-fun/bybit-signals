+def _group_dro_main_bce_loss(
+    logits: Tensor,
+    targets: Tensor,
+    sample_weight: Tensor,
+    group_ids: Tensor,
+    group_dro_lambda: float,
+) -> tuple[Tensor, Tensor, Tensor]:
+    per_row_loss = F.binary_cross_entropy_with_logits(logits, targets, reduction="none")
+    weights = torch.clamp(sample_weight, min=0.0)
+    erm_main = _weighted_bce_loss(logits, targets, weights)
+    unique_groups = torch.unique(group_ids)
+    group_losses: list[Tensor] = []
+    for g in unique_groups:
+        g_mask = group_ids == g
+        gw = weights[g_mask]
+        if int(gw.numel()) == 0:
+            continue
+        g_denom = torch.sum(gw)
+        if float(g_denom.item()) <= 0.0:
+            continue
+        g_loss = torch.sum(per_row_loss[g_mask] * gw) / g_denom
+        group_losses.append(g_loss)
+    if not group_losses:
+        return erm_main, erm_main.detach(), erm_main.detach()
+    group_tensor = torch.stack(group_losses)
+    worst_group = torch.max(group_tensor)
+    best_group = torch.min(group_tensor)
+    mixed = (1.0 - float(group_dro_lambda)) * erm_main + float(group_dro_lambda) * worst_group
+    return mixed, worst_group.detach(), best_group.detach()
+
