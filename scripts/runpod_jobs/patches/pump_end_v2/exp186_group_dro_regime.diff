+def _group_distance_median(frame: pd.DataFrame) -> float:
+    if "distance_from_episode_high_pct" not in frame.columns:
+        return 0.0
+    values = pd.to_numeric(frame["distance_from_episode_high_pct"], errors="coerce")
+    median = float(values.median(skipna=True)) if len(values) > 0 else 0.0
+    if not np.isfinite(median):
+        return 0.0
+    return median
+
+
+def _build_group_ids(
+    frame: pd.DataFrame,
+    *,
+    group_mode: str,
+    train_distance_median: float | None = None,
+) -> np.ndarray:
+    n = len(frame)
+    if group_mode != "age_x_distance":
+        return np.zeros(n, dtype=np.int64)
+    distance_median = float(train_distance_median) if train_distance_median is not None else _group_distance_median(frame)
+    if "episode_age_bars" in frame.columns:
+        age = pd.to_numeric(frame["episode_age_bars"], errors="coerce").fillna(0)
+    else:
+        age = pd.Series(np.zeros(n, dtype=np.float64))
+    age_bucket = (age.to_numpy(dtype=np.float64, copy=False) > 2.0).astype(np.int64)
+    if "distance_from_episode_high_pct" in frame.columns:
+        distance = pd.to_numeric(frame["distance_from_episode_high_pct"], errors="coerce")
+    else:
+        distance = pd.Series(np.full(n, np.nan, dtype=np.float64))
+    distance = distance.fillna(distance_median)
+    distance_bucket = (
+        distance.to_numpy(dtype=np.float64, copy=False) > float(distance_median)
+    ).astype(np.int64)
+    return (age_bucket * 2 + distance_bucket).astype(np.int64, copy=False)
+
